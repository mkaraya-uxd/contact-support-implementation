  const sel     = document.getElementById('country-select');
  const proNum  = document.getElementById('pro-number');
  const proNote = document.getElementById('pro-note');
  const premNum = document.getElementById('premium-number');
  const premNote= document.getElementById('premium-note');

  function updateNumbers() {
    const d = phones[sel.value]; if (!d) return;
    if(proNum)  proNum.textContent  = d.pro;
    if(proNote) proNote.textContent = d.note;
    if(premNum) premNum.textContent = d.premium;
    if(premNote)premNote.textContent= d.premNote;
    // Mobile buttons
    const mPro     = document.getElementById('pro-number-mob');
    const mPrem    = document.getElementById('premium-number-mob');
    const mProNote = document.getElementById('pro-note-mob');
    const mPremNote= document.getElementById('premium-note-mob');
    if(mPro)     mPro.textContent      = d.premium;
    if(mPrem)    mPrem.textContent     = d.premium;
    if(mProNote) mProNote.textContent  = d.note;
    if(mPremNote)mPremNote.textContent = d.premNote;
  }
  sel.addEventListener('change', updateNumbers);
  updateNumbers();

  /* ── GLOBAL TOOLTIP ── */
  const tip = document.createElement('div');
  tip.id = 'global-tooltip';
  document.body.appendChild(tip);

  function showTip(text, el) { tip.textContent = text; tip.classList.add('visible'); posTip(el); }
  function hideTip()          { tip.classList.remove('visible'); }
  function posTip(el) {
    const r = el.getBoundingClientRect();
    tip.style.left = (r.left + r.width / 2) + 'px';
    tip.style.top  = (r.top - 8) + 'px';
    tip.style.transform = 'translateX(-50%) translateY(-100%)';
  }
  document.querySelectorAll('.has-tooltip').forEach(el => {
    const label = el.dataset.tip;
    el.addEventListener('mouseenter', () => showTip(label, el));
    el.addEventListener('mousemove',  () => posTip(el));
    el.addEventListener('mouseleave', hideTip);
  });

  /* ── TABLE COLUMN HOVER ── */
  const colToCard = {'1':'card-free','2':'card-starter','3':'card-pro','4':'card-premium'};
  function applyHover(col, on) {
    const card = document.getElementById(colToCard[col]);
    if (card) card.classList.toggle('is-highlighted', on);
    document.querySelectorAll(
      '.channel-table th[data-col="'+col+'"], '+
      '.channel-table td:nth-child('+(parseInt(col,10)+1)+')'
    ).forEach(el => el.classList.toggle('cell-hovered', on));
  }
  document.querySelectorAll('.channel-table th[data-col]').forEach(th => {
    const col = th.getAttribute('data-col');
    th.addEventListener('mouseenter', () => applyHover(col, true));
    th.addEventListener('mouseleave', () => applyHover(col, false));
  });
  document.querySelectorAll('.channel-table tbody tr').forEach(row => {
    row.querySelectorAll('td').forEach((td, i) => {
      if (i === 0) return;
      const col = String(i);
      td.addEventListener('mouseenter', () => applyHover(col, true));
      td.addEventListener('mouseleave', () => applyHover(col, false));
    });
  });

  /* ── MODAL ── */
  const overlay  = document.getElementById('proto-overlay');
  const closeBtn = document.getElementById('proto-close');
  function openModal(e) { e.preventDefault(); overlay.classList.add('open'); closeBtn.focus(); }
  function closeModal()  { overlay.classList.remove('open'); }
  document.querySelectorAll('a').forEach(el => el.addEventListener('click', openModal));
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if(e.target===overlay) closeModal(); });
  document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });
</script>
