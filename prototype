<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact Support – V6</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Lexend+Deca:wght@300;400;500;600&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg:           #f8f5ee;
  --container-01: #ffffff;
  --container-02: rgba(255,255,255,0.46);
  --border:       rgba(0,0,0,0.11);
  --border-input: rgba(0,0,0,0.47);
  --text-01:      #1f1f1f;
  --text-02:      rgba(0,0,0,0.62);
  --heading-color:#213343;
  --orange:       #ff4800;
  --orange-alt:   #ff5c35;
  --green-badge:  #b9cdbe;
  --lavender:     #d6c2d9;
  --badge-border: rgba(255,255,255,0.08);
  --cyan:         #E0F7FA;
  --font:         'Lexend Deca', sans-serif;
}

body {
  background: var(--bg);
  font-family: var(--font);
  color: var(--text-01);
  min-height: 100vh;
}

/* ── PAGE ── */
.page {
  width: 1080px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
  padding-bottom: 96px;
}

/* ── HEADER ── */
.header-container {
  width: 692px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 24px;
}
.page-heading {
  font-size: 32px;
  font-weight: 500;
  line-height: 44px;
  color: var(--heading-color);
  text-align: center;
  width: 100%;
}

/* ── BODY ROW ── */
.body-row {
  width: 100%;
  display: flex;
  gap: 24px;
  align-items: flex-start;
}

/* ── LEFT COL ── */
.left-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ── FLAT TEXT CARDS ── */
.text-item {
  background: var(--container-01);
  border: 2px solid var(--border);
  border-radius: 8px;
  padding: 12px;
  font-size: 16px;
  line-height: 28px;
  font-weight: 400;
  color: var(--text-01);
  transition: background 0.15s ease;
}
.tier-free    { color: var(--orange);     font-weight: 500; }
.tier-starter { color: var(--orange-alt); font-weight: 500; }
.tier-pro     { color: var(--orange-alt); font-weight: 500; }
.text-item a  {
  font-weight: 600;
  text-decoration: underline;
  text-decoration-color: var(--text-01);
  color: var(--text-01);
  cursor: pointer;
}

/* ── PRO CARD ── */
.pro-card {
  background: var(--container-01);
  border: 2px solid var(--border);
  border-radius: 8px;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: background 0.15s ease;
}
.pro-card-heading {
  font-size: 16px;
  line-height: 28px;
  font-weight: 400;
  color: var(--text-01);
}

/* ── PHONE SECTION ── */
.phone-section { display: flex; flex-direction: column; gap: 12px; }
.phone-label {
  font-size: 14px; font-weight: 600; line-height: 20px;
  letter-spacing: 0.1px; color: var(--text-01); margin-bottom: 8px;
}
.phone-row { display: flex; align-items: flex-end; gap: 16px; }

.select-wrap { position: relative; flex-shrink: 0; }
.country-select {
  height: 40px;
  background: var(--container-02);
  border: 1px solid var(--border-input);
  border-radius: 4px;
  padding: 0 40px 0 16px;
  font-size: 16px; font-family: var(--font); font-weight: 300;
  color: var(--text-01); line-height: 28px;
  appearance: none; -webkit-appearance: none; cursor: pointer;
}
.select-arrow {
  position: absolute; right: 8px; top: 50%;
  transform: translateY(-50%);
  pointer-events: none; width: 24px; height: 24px;
}

.phone-number-group { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.phone-number {
  font-size: 16px; font-weight: 600; line-height: 28px;
  color: var(--text-01); white-space: nowrap;
}
.ext-badge {
  display: inline-flex; align-items: center; justify-content: center;
  border-radius: 4px; padding: 4px 8px;
  font-size: 14px; font-weight: 600; line-height: 20px;
  color: var(--text-01); white-space: nowrap;
  border: 1px solid var(--badge-border);
}
.ext-badge.green    { background: var(--green-badge); }
.ext-badge.lavender { background: var(--lavender); }

.phone-note {
  font-size: 12px; font-weight: 500; line-height: 20px;
  color: var(--text-02); margin-top: 8px;
}

/* ── PREMIUM SUBCARD ── */
.premium-card {
  background: var(--bg);
  border: 2px solid var(--border);
  border-radius: 8px;
  padding: 12px;
  display: flex; flex-direction: column; gap: 12px;
  transition: background 0.15s ease;
}
.premium-title {
  font-size: 16px; font-weight: 600; line-height: 28px;
  color: var(--orange); white-space: nowrap;
}
.premium-line-row {
  display: flex; align-items: center;
  justify-content: space-between; gap: 8px; flex-wrap: nowrap;
}
.premium-line-label {
  font-size: 14px; font-weight: 600; line-height: 20px;
  color: var(--text-01); white-space: nowrap;
}
.premium-line-number {
  font-size: 16px; font-weight: 600; line-height: 28px;
  color: var(--text-01); white-space: nowrap;
}
.premium-line-note {
  font-size: 12px; font-weight: 500; line-height: 20px;
  color: var(--text-02); white-space: nowrap;
}
.premium-desc {
  font-size: 14px; font-weight: 300; line-height: 22px; color: var(--text-02);
}
.premium-desc a {
  font-weight: 600; text-decoration: underline;
  text-decoration-color: var(--text-02); color: var(--text-02); cursor: pointer;
}

/* ── RIGHT COL ── */
.right-col {
  width: 500px; flex-shrink: 0; flex-grow: 0;
  display: flex; flex-direction: column; gap: 16px;
}

/* ── TABLE ── */
.channel-table {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  border-collapse: separate;
  border-spacing: 0;
  table-layout: fixed;
}
.channel-table col.col-label { width: 113px; }
.channel-table th,
.channel-table td {
  padding: 10px; border: none;
  font-size: 14px; font-family: var(--font);
  color: var(--text-01); vertical-align: middle;
  background: var(--container-01);
  transition: background 0.15s ease;
}
.channel-table thead th {
  background: rgba(255,255,255,0.46);
  font-weight: 600; line-height: 20px;
  letter-spacing: 0.1px; text-align: center;
}
.channel-table thead th:first-child { text-align: left; }
.channel-table tbody td:first-child {
  font-weight: 300; line-height: 22px; text-align: left;
}
.channel-table tbody td:not(:first-child) {
  text-align: center; height: 44px;
}
.channel-table tbody tr + tr td {
  box-shadow: inset 0 1px 0 rgba(0,0,0,0.11);
}
.channel-table th.cell-hovered,
.channel-table td.cell-hovered { background: var(--cyan) !important; }
.check-circle { width: 24px; height: 24px; }

/* ── CARD HIGHLIGHTS ── */
.text-item.is-highlighted   { background: var(--cyan); }
.pro-card.is-highlighted    { background: var(--cyan); }
.premium-card.is-highlighted { background: var(--cyan); }

/* ── TOOLTIPS ── */
.has-tooltip { cursor: pointer; }
.has-tooltip.no-pointer { cursor: default; }
#global-tooltip {
  position: fixed;
  background: #1f1f1f; color: #fff;
  font-family: var(--font); font-size: 13px; font-weight: 500; line-height: 20px;
  white-space: nowrap; padding: 6px 12px; border-radius: 6px;
  pointer-events: none; opacity: 0; transition: opacity 0.12s ease;
  z-index: 9998; transform: translateX(-50%);
}
#global-tooltip.visible { opacity: 1; }
#global-tooltip::after {
  content: ''; position: absolute; top: 100%; left: 50%;
  transform: translateX(-50%);
  border: 5px solid transparent; border-top-color: #1f1f1f;
}

/* ── UTILITY LINKS ── */
.utility-links { display: flex; flex-direction: column; gap: 16px; }
.utility-line {
  font-size: 14px; font-weight: 300; line-height: 22px;
  color: rgba(0,0,0,0.62);
}
.utility-line a {
  font-weight: 600; text-decoration: underline;
  text-decoration-color: rgba(0,0,0,0.62);
  color: rgba(0,0,0,0.62); cursor: pointer;
}

/* ════════════════════════════════
   TABLET  600px – 1079px
════════════════════════════════ */
@media (min-width: 600px) and (max-width: 1079px) {
  .page { width: 100%; padding-left: 40px; padding-right: 40px; }
  .header-container { width: 100%; }
  .body-row { flex-direction: column; gap: 0; }
  .left-col { width: 100%; flex: none; gap: 8px; margin-bottom: 16px; }
  .right-col { width: 100%; flex-shrink: 1; flex-grow: 1; }
  .channel-table { width: 100%; }
  .phone-row { flex-direction: row; align-items: center; flex-wrap: nowrap; gap: 16px; }
  .country-select { width: 250px; }
  .select-wrap    { width: 250px; }
  .phone-note { margin-top: 0; white-space: nowrap; }
  .premium-line-row { flex-wrap: nowrap; gap: 8px; }
  /* Hide mobile-only on tablet */
  .mob-only { display: none !important; }
}

/* ════════════════════════════════
   MOBILE  ≤ 599px
════════════════════════════════ */

/* Mobile-only elements are hidden everywhere above 599px */
.mob-only { display: none; }

@media (max-width: 599px) {

  /* Page */
  .page { width: 100%; padding-left: 16px; padding-right: 16px; gap: 24px; }
  .header-container { width: 100%; }

  /* Layout: single column */
  .body-row { flex-direction: column; gap: 0; }
  .left-col { width: 100%; flex: none; gap: 8px; margin-bottom: 16px; }
  .right-col { width: 100%; flex-shrink: 1; flex-grow: 1; gap: 16px; }

  /* Hide desktop table and utility links */
  .channel-table { display: none; }
  .utility-links  { display: none; }

  /* Hide desktop number elements, show mobile alternatives */
  .desk-only { display: none; }
  .mob-only  { display: flex; }

  /* Phone select: full width */
  .phone-row { flex-direction: column; align-items: flex-start; gap: 12px; }
  .select-wrap, .country-select { width: 100%; }

  /* Premium dedicated line: stack label above button row */
  .premium-line-row { flex-direction: column; align-items: flex-start; gap: 8px; }

  /* Orange call button */
  .mob-btn {
    background: #ff4800; color: #fff; border: none;
    border-radius: 8px; padding: 8px 16px;
    font-family: var(--font); font-size: 14px; font-weight: 500;
    line-height: 24px; white-space: nowrap; cursor: default; flex-shrink: 0;
  }

  /* Mobile number row: button + badge + note inline */
  .mob-num-row {
    display: flex; align-items: center; gap: 8px; width: 100%; flex-wrap: nowrap;
  }
  .mob-num-note {
    font-size: 12px; font-weight: 500; line-height: 20px;
    color: rgba(0,0,0,0.62); white-space: nowrap;
  }

  /* Mobile plan card */
  .mob-plan-card {
    background: var(--container-01);
    border: 1px solid var(--border); border-radius: 8px; padding: 16px;
    display: flex; flex-direction: column; gap: 12px; width: 100%;
  }
  .mob-plan-heading {
    font-size: 18px; font-weight: 600; line-height: 28px;
    letter-spacing: 0.1px; color: var(--text-01);
  }
  .mob-divider { height: 1px; background: #dbe4ed; width: 100%; }
  .mob-tier-block { display: flex; flex-direction: column; gap: 8px; }
  .mob-tier-name {
    font-size: 16px; font-weight: 600; line-height: 28px;
    letter-spacing: 0.1px; color: var(--text-01);
  }
  .mob-chips { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  .mob-chip {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
    padding: 4px 8px; font-size: 14px; font-weight: 600; line-height: 20px;
    letter-spacing: 0.1px; color: var(--text-01); white-space: nowrap;
  }

  /* Mobile utility links */
  .mob-utility { display: flex; flex-direction: column; gap: 16px; }
}

/* ── PROTOTYPE MODAL ── */
.proto-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(31,31,31,0.45);
  backdrop-filter: blur(2px); z-index: 9999;
  align-items: center; justify-content: center;
}
.proto-overlay.open { display: flex; }
.proto-modal {
  background: #fff; border-radius: 16px; padding: 28px 28px 24px;
  width: 100%; max-width: 400px; margin: 20px;
  box-shadow: 0 8px 40px rgba(31,31,31,0.18);
  display: flex; flex-direction: column; gap: 14px;
  animation: pop-in 0.18s ease;
}
@keyframes pop-in {
  from { opacity:0; transform:translateY(8px) scale(0.97); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}
.proto-modal-icon { width:40px; height:40px; background:#fff4f0; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.proto-modal-icon svg { width:20px; height:20px; }
.proto-modal-title { font-weight:500; font-size:17px; line-height:24px; color:#1f1f1f; }
.proto-modal-body  { font-weight:300; font-size:14px; line-height:22px; color:#555; }
.proto-modal-footer { display:flex; justify-content:flex-end; padding-top:4px; }
.proto-modal-btn {
  background:#1f1f1f; color:#fff; border:none; border-radius:8px;
  padding:9px 22px; font-family:var(--font); font-size:14px; font-weight:500;
  cursor:pointer;
}
.proto-modal-btn:hover { background:#3a3a3a; }
</style>
